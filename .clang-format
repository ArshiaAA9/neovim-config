BasedOnStyle: LLVM

# Customizations for short if statements
AllowShortIfStatementsOnASingleLine: Always
AllowShortBlocksOnASingleLine: false
AllowShortLoopsOnASingleLine: true
BreakTemplateDeclarations: Yes
IndentCaseLabels: true
# Force vertical alignment for long params
BinPackParameters: false
AlignAfterOpenBracket: AlwaysBreak
BraceWrapping:
  AfterControlStatement: Never
# Group includes by type
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<.*\.h>'
    Priority: 1
  - Regex: '^<.*'
    Priority: 2
  - Regex: '.*'
    Priority: 3
UseTab : Never
IndentWidth: 4
ColumnLimit: 120
PointerAlignment: Left
AccessModifierOffset: -4
# Force the colon to be placed on the next line
BreakConstructorInitializers: BeforeColon

# Force each initializer to be on its own line
BreakConstructorInitializersBeforeComma: true

# Prevent clang-format from packing initializers into a single line
AllowAllConstructorInitializersOnNextLine: false
SeparateDefinitionBlocks: Always  # Add empty lines between function definitions
...
